# =============================================================
# clipto / kuick-clone — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git.
# =============================================================

# ── Database ──────────────────────────────────────────────────
# Get this from: https://neon.tech  or  https://supabase.com
# Format (Neon):     postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# Format (Supabase): postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Object Storage (Cloudflare R2 or AWS S3) ─────────────────
# Cloudflare R2: https://dash.cloudflare.com → R2 → API Tokens
STORAGE_REGION="auto"
STORAGE_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
STORAGE_ACCESS_KEY_ID="your-r2-access-key"
STORAGE_SECRET_ACCESS_KEY="your-r2-secret-key"
STORAGE_BUCKET_NAME="clipto-files"

# ── Redis / Upstash (rate limiting + slug cache) ──────────────
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="clipto"

# ── Rate Limiting ─────────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_MAX="10"
RATE_LIMIT_WINDOW="60"   # seconds
